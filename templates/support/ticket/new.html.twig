{# templates/support/ticket/new.html.twig #}

{% extends 'base.html.twig' %}

{% form_theme form with ['form/supportdesk_theme.html.twig'] only %}


{% block title %}Créer un ticket - SupportDesk{% endblock %}

{% block body %}
    <p>
        <a href="{{ path('support_ticket_index') }}">
            <- Retour aux tickets
        </a>
    </p>

    <div class="card">
        <h1>Créer un ticket</h1>

        {{ form_start(form, { 'attr': { 'novalidate': 'novalidate' }}) }}
            {{ form_row(form.title) }}
            {{ form_row(form.customerEmail) }}
            {{ form_row(form.description) }}
            {{ form_row(form.priority) }}

            {% if form.escalationReason is defined %}
                {{ form_row(form.escalationReason) }}
            {% endif %}

            {{ form_row(form.relatedTicket) }}
            {{ form_row(form.submit) }}
        {{ form_end(form) }}
    </div>
{% endblock %}
