{# templates/support/ticket/show.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}{{ ticket.reference }} - SupportDesk{% endblock %}

{% block body %}
    <p>
        <a href="{{ path('support_ticket_index') }}">
            <- Retour aux tickets
        </a>
    </p>

    <article class="card">
        <h1>{{ ticket.reference }}</h1>

        <dl>
            <dt>Titre</dt>
            <dd>{{ ticket.title }}</dd>

            <dt>Email client</dt>
            <dd>{{ ticket.customerEmail }}</dd>

            <dt>Statut</dt>
            <dd>
                <span class="badge">{{ ticket.status.value }}</span>
            </dd>

            <dt>Description</dt>
            <dd>{{ ticket.description }}</dd>

            <dt>Ticket lié</dt>
            <dd>
                {% if ticket.relatedTicketReference %}
                    <a href="{{ path('support_ticket_show', { reference: ticket.relatedTicketReference }) }}">
                        {{ ticket.relatedTicketReference }}
                    </a>
                {% else %}
                    Aucun
                {% endif %}
            </dd>

            <dt>Pièce jointe</dt>
            <dd>
                {% if ticket.attachment %}
                    {{ ticket.attachment.originalName }}

                    <small>
                        -
                        {{ (ticket.attachment.size / 1000)|number_format(1, ',', ' ') }}
                        Ko
                        -
                        {{ ticket.attachment.mediaType ?? 'type inconnu' }}
                    </small>
                {% else %}
                    Aucune
                {% endif %}
            </dd>
        </dl>
    </article>
{% endblock %}
